rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'createdAt']) && data.keys().size() == 3
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidUserUpdate(data) {
      return data.displayName is string && data.displayName.size() <= 100;
    }

    // Context: users
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidUser(incoming());

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidUserUpdate(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt'])
        && incoming().updatedAt == request.time;
      
      allow delete: if false;
    }
  }
}
